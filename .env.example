# Database Configuration
# For production, use strong credentials and environment-specific database
DATABASE_URL=postgresql://username:password@host:5432/batjetkiret

# Security Configuration
# CRITICAL: Use strong, randomly generated secret key for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# Debug Mode
# Set to False in production
DEBUG=False

# Allow order creation without user balance
ALLOW_ORDER_WITHOUT_BALANCE=False

# Allowed CORS Origins
# For production, use specific domain names
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging Configuration
LOG_LEVEL=INFO
LOG_JSON=True

# Service Identification
SERVICE_NAME=batjetkiret-backend
