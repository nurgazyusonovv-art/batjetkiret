# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (local dev, default):
DATABASE_URL=sqlite:///./batjetkiret.db

# PostgreSQL (production — uncomment and fill in):
# DATABASE_URL=postgresql://user:password@localhost:5432/batjetkiret

# ─── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=local-dev-secret-key-change-me

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=True
ALLOW_ORDER_WITHOUT_BALANCE=False

# Public base URL (used for building screenshot URLs etc.)
BASE_URL=http://localhost:8000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. In production set to your real domains.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174,http://localhost:5175

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=False
SERVICE_NAME=batketkiret-backend
