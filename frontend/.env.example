# Environment переменналары (мисал)

# API базалык URL (автоматтык түрдө аныкталат, керек болсо override кылыңыз)
# API_BASE_URL=http://localhost:8000

# Yandex API ачкычы (Router жана Geocoding үчүн)
# Алуу: https://console.cloud.yandex.ru/
# YANDEX_API_KEY=ваш_yandex_api_ключ_здесь

# Refresh intervals (секундаларда)
# REFRESH_HOME_ACTIVE_INTERVAL=5
# REFRESH_HOME_IDLE_INTERVAL=15
# REFRESH_ORDERS_ACTIVE_INTERVAL=5
# REFRESH_ORDERS_IDLE_INTERVAL=12
# REFRESH_PROFILE_INTERVAL=30
# REFRESH_MAX_BACKOFF_MINUTES=1
